# Copy to `.env` and fill in values. Never commit `.env`.
# Lines starting with # are ignored. Optional: use `.env.local` for overrides (also gitignored).

# --- HTTP ---
PORT=3000
# BIND_HOST=0.0.0.0
# APP_DISPLAY_NAME=Easy NL2SQL

# --- LLM (guided lessons, generate-sql, explain) ---
ENABLE_LLM_SQL_GEN=true
LLM_API_KEY=
# LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_MS=15000
# SQL_GENERATION_MODE=hybrid
# Guided path “Load lesson” (default 2800 completion tokens — enough for full chapter; raise if truncated, 90s timeout):
# GUIDED_EXPAND_MAX_TOKENS=2800
# GUIDED_EXPAND_TIMEOUT_MS=90000

# --- ElevenLabs: guided path “Listen” → POST /guided-podcast-tts (MP3) ---
# Create at https://elevenlabs.io → Profile / API keys (xi-api-key). Not OpenAI sk-… keys.
ELEVENLABS_API_KEY=
# Female premade voices (defaults): Rachel = primary, Bella = optional second speaker (must differ).
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Default server: turbo first (faster Listen), multilingual fallback if turbo fails on your account.
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_FALLBACK_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# Optional smaller/faster MP3 (may require a higher ElevenLabs tier): mp3_44100_96
# ELEVENLABS_TIMEOUT_MS=120000
# Two-voice Listen: second female voice id (API still labels turns professor|student):
# ELEVENLABS_DIALOGUE_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_TTS_PARALLEL=8
# ELEVENLABS_DIALOGUE_TURN_MAX=2000

# --- Oracle (optional; Run on DB) ---
# EXECUTE_SQL_ENABLED=true
# DB_DSN=
# DB_USER=
# DB_PASSWORD=
# ORACLE_WALLET_PATH=
# ORACLE_WALLET_ZIP_B64=

# --- Book (optional) ---
# BOOK_EPUB_PATH=
# BOOK_EPUB_URL=
