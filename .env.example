# Copy to `.env` and fill in values. Never commit `.env`.
# Lines starting with # are ignored. Optional: use `.env.local` for overrides (also gitignored).

# --- HTTP ---
PORT=3000
# BIND_HOST=0.0.0.0
# APP_DISPLAY_NAME=Easy NL2SQL

# --- LLM (guided lessons, generate-sql, explain) ---
ENABLE_LLM_SQL_GEN=true
LLM_API_KEY=
# LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_MS=15000
# SQL_GENERATION_MODE=hybrid

# --- ElevenLabs: guided path “Listen” → POST /guided-podcast-tts (MP3) ---
# Create at https://elevenlabs.io → Profile / API keys (xi-api-key). Not OpenAI sk-… keys.
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_FALLBACK_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_TIMEOUT_MS=120000
# Conversational “Listen” (two voices via POST /v1/text-to-dialogue, default model eleven_v3):
# ELEVENLABS_DIALOGUE_VOICE_ID=pNInz6obpgDQGcFmaJgB
# ELEVENLABS_DIALOGUE_MODEL_ID=eleven_v3
# ELEVENLABS_DIALOGUE_BATCH_CHARS=9000
# ELEVENLABS_DIALOGUE_TURN_MAX=2000

# --- Oracle (optional; Run on DB) ---
# EXECUTE_SQL_ENABLED=true
# DB_DSN=
# DB_USER=
# DB_PASSWORD=
# ORACLE_WALLET_PATH=
# ORACLE_WALLET_ZIP_B64=

# --- Book (optional) ---
# BOOK_EPUB_PATH=
# BOOK_EPUB_URL=
